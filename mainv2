<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>La Main Verte - Multijoueur Realtime</title>
    <script src="https://www.gstatic.com/firebasejs/9.17.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.17.1/firebase-database-compat.js"></script>
    
    <style>
        /* [Tes styles CSS restent exactement les mêmes, ils ne changent pas] */
        :root { --p1: #2e7d32; --bg: #f4f7f1; --potager: #81c784; --verger: #fff176; --amenag: #ffccbc; --batiment: #455a64; --dark: #263238; --gold: #ffd700; --serre: #e1f5fe; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); margin: 0; display: flex; height: 100vh; overflow: hidden; }
        .main-game { flex: 1; display: flex; flex-direction: column; padding: 10px; overflow-y: auto; }
        .sidebar { width: 420px; background: white; border-left: 2px solid #ddd; padding: 10px; display: flex; flex-direction: column; }
        .hud { display: flex; justify-content: space-between; background: white; padding: 10px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 10px; font-weight: bold; }
        .farm-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; background: #d7ccc8; padding: 10px; border-radius: 12px; }
        .zone { min-height: 155px; background: #efebe9; border: 2px dashed #bcaaa4; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; font-size: 0.72em; cursor: pointer; text-align: center; }
        .zone.selected { border: 3px solid #ff9800 !important; }
        .tuile-potager { background: var(--potager) !important; border: 2px solid #2e7d32 !important; }
        .tuile-verger { background: var(--verger) !important; border: 2px solid #fbc02d !important; }
        .tuile-amenag { background: var(--amenag) !important; border: 2px solid #ff5722 !important; }
        .tuile-batiment { background: var(--batiment) !important; border: 2px solid #263238 !important; color: white; }
        .has-serre { box-shadow: inset 0 0 15px rgba(3, 169, 244, 0.6); border: 3px solid #03a9f4 !important; background: var(--serre) !important; }
        .up-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-bottom: 10px; }
        .up-card { background: #f1f1f1; padding: 6px; border-radius: 4px; border: 1px solid #ccc; font-size: 0.75em; }
        .btn-up { width: 100%; font-size: 0.85em; cursor: pointer; margin-top: 4px; background: white; border: 1px solid #999; border-radius: 3px; font-weight: bold; }
        .card { border: 1px solid #ddd; border-radius: 6px; padding: 8px; margin-bottom: 5px; background: white; font-size: 0.75em; }
        .scroll-area { flex: 1; overflow-y: auto; border: 1px solid #eee; padding: 5px; border-radius: 4px; }
        .logs { height: 80px; background: var(--dark); color: #a5d6a7; padding: 8px; font-family: monospace; font-size: 0.7em; overflow-y: auto; border-radius: 6px; }
        .btn-action { width: 100%; padding: 8px; border: none; border-radius: 4px; font-weight: bold; color: white; cursor: pointer; font-size: 0.72em; margin-bottom: 4px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .btn-cost { font-size: 0.8em; font-weight: normal; margin-top: 2px; opacity: 0.9; }
        button:disabled { background: #cfd8dc !important; color: #78909c !important; cursor: not-allowed !important; }
        .market-preview { background: #fffde7; padding: 6px; border: 1px solid #ffd54f; border-radius: 6px; font-size: 0.72em; margin-bottom: 6px; }
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 100; align-items: center; justify-content: center; }
        .modal-content { background: #fff; padding: 20px; border-radius: 12px; width: 90%; max-width: 900px; }
        .rayon-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; }
        .rayon { background: #f9f9f9; padding: 10px; border-radius: 8px; border: 1px solid #ccc; }
        .jard-card { border: 2px solid #ddd; padding: 10px; border-radius: 6px; margin-bottom: 8px; cursor: pointer; position: relative; }
        .price-tag { position: absolute; top: -8px; right: -8px; background: var(--gold); padding: 3px 6px; border-radius: 10px; font-size: 0.9em; font-weight: bold; }
        .aux-tray { display: flex; gap: 5px; margin-bottom: 8px; background: #e3f2fd; padding: 5px 10px; border-radius: 5px; border: 1px solid #90caf9; }
        .aux-icon { background: white; border: 1px solid #90caf9; padding: 2px 6px; border-radius: 4px; font-size: 0.75em; font-weight: bold; }
    </style>
</head>
<body>

<div class="main-game">
    <div class="hud">
        <div id="season-display">📅 Saison...</div>
        <div>💰 <span id="res-money">0</span> | ⏳ <span id="res-time">0</span>/<span id="res-timemax">0</span>h</div>
        <div>💩 Compost: <span id="res-compost">0</span></div>
        <div id="meteo-display" style="color:#1565c0;">🎲 --</div>
    </div>
    <div id="ravageur-alert" style="background:#ffebee; color:#c62828; padding:5px; font-size:0.8em; text-align:center; display:none; border-radius:5px; margin-bottom:5px;"></div>
    <div id="aux-tray" class="aux-tray" style="display:none;"></div>
    <div class="farm-grid" id="farm-grid"></div>
    <div class="logs" id="game-logs">> Initialisation du multijoueur...</div>
    <div id="action-buttons-container" style="display: grid; grid-template-columns: repeat(4, 1fr); gap:4px; margin-top:10px;">
        </div>
</div>

<div class="sidebar">
    <h3>⚙️ Améliorations</h3>
    <div class="up-grid" id="up-grid"></div>
    <h3>🛒 Jardinerie (En Vitrine)</h3>
    <div class="market-preview" id="market-preview"></div>
    <div id="jardinerie-buttons-container" style="display:grid; grid-template-columns: 1fr 1fr; gap:4px;"></div>
    <h3>🎒 Ma Main</h3>
    <div class="scroll-area" id="player-hand"></div>
</div>

<div class="modal-overlay" id="jardinerie-modal">
    <div class="modal-content" id="modal-content-inner"></div>
</div>

<script>

const firebaseConfig = {
  apiKey: "AIzaSyA_OHv6TDiVsn4PwM9s25gij8lBwQH8xrg",
  authDomain: "main-verte-72483.firebaseapp.com",
  projectId: "main-verte-72483",
  storageBucket: "main-verte-72483.firebasestorage.app",
  messagingSenderId: "633454274346",
  appId: "1:633454274346:web:7261efcfe1b9cecdd6e053",
  measurementId: "G-5EWS2ZMBCV"
};

    firebase.initializeApp(firebaseConfig);
    const db = firebase.database().ref("la-main-verte-partie-1");

    // Données constantes du jeu (Deck, Saisons, etc.)
    const DECKS = {
        C: [
            { nom: "Radis", prix: 0, e: 1, s: 1, t: 1, g: 3, cat: 'L', semis: ['P','E','A','H'], rec: ['P','E','A','H'] },
            { nom: "Carotte", prix: 1, e: 4, s: 2, t: 1, g: 6, cat: 'L', semis: ['P','E'], rec: ['A','H'] },
            { nom: "Pommier", prix: 2, e: 12, s: 5, t: 3, g: 15, cat: 'A', semis: ['A','H'], rec: ['E','A'] }
        ],
        S: [{ nom: "Fumier", prix: 2, t: 1, cat: 'Soutien', desc: "Gain de +2💩 Compost." }],
        A: [{ nom: "Hérisson", prix: 2, t: 1, cat: 'Auxiliaire', prot: "Limaces" }]
    };
    const UP_NAMES = ["Agrandissement", "Efficacité", "Formation", "Qualité Sol", "Microclimat", "Bricoleur", "Fidélité", "Pass VIP"];
    const ALL_SEASONS = ["P","E","A","H"];

    // État local du jeu
    let state = null;
    let localSelectedZone = null;

    // 1. ÉCOUTEUR FIREBASE : Met à jour le jeu quand quelqu'un d'autre joue
    db.on("value", (snapshot) => {
        const data = snapshot.val();
        if (!data) {
            initNewGame(); // Crée une partie si vide
        } else {
            state = data;
            render();
        }
    });

    // 2. ENVOI DES MODIFICATIONS : Sauvegarde vers Firebase
    function syncState() {
        db.set(state);
    }

    function initNewGame() {
        state = {
            annee: 1, saisonIdx: 0, money: 10, time: 10, timeMax: 10, compost: 3,
            upgrades: Array(8).fill(1), hand: [], auxActifs: [],
            zones: Array(6).fill(null).map((_, i) => ({ id: i, type: i === 0 ? "LIFE" : null, culture: null, batiment: null })),
            market: { 
                C: [{ nom: "Radis", prix: 0, e: 1, s: 1, t: 1, g: 3, cat: 'L', semis: ['P','E','A','H'], rec: ['P','E','A','H'] }, { nom: "Carotte", prix: 1, e: 4, s: 2, t: 1, g: 6, cat: 'L', semis: ['P','E'], rec: ['A','H'] }], 
                S: [{ nom: "Fumier", prix: 2, t: 1, cat: 'Soutien', desc: "Gain de +2💩 Compost." }, { nom: "Fumier", prix: 2, t: 1, cat: 'Soutien', desc: "Gain de +2💩 Compost." }], 
                A: [{ nom: "Hérisson", prix: 2, t: 1, cat: 'Auxiliaire', prot: "Limaces" }, { nom: "Hérisson", prix: 2, t: 1, cat: 'Auxiliaire', prot: "Limaces" }]
            },
            picksLeft: 0,
            modalOpen: false
        };
        syncState();
    }

    // 3. LOGIQUE DE RENDU (Inspiré de tes versions précédentes)
    function render() {
        if (!state) return;

        // Mise à jour HUD
        document.getElementById('res-money').innerText = state.money;
        document.getElementById('res-time').innerText = state.time;
        document.getElementById('res-timemax').innerText = state.timeMax;
        document.getElementById('res-compost').innerText = state.compost;
        document.getElementById('season-display').innerText = `📅 ${["Printemps","Été","Automne","Hiver"][state.saisonIdx]} - An ${state.annee}`;

        // Grille
        const grid = document.getElementById('farm-grid');
        grid.innerHTML = "";
        state.zones.forEach(z => {
            const d = document.createElement('div');
            const accessible = z.id <= (state.upgrades[0] === 1 ? 3 : (state.upgrades[0] === 2 ? 4 : 5));
            const isSerre = z.batiment === 'SERRE';
            let tClass = z.type ? 'tuile-'+z.type.toLowerCase() : '';
            if(z.batiment && !isSerre) tClass = 'tuile-batiment';
            if(isSerre) tClass += ' has-serre'; 
            
            d.className = `zone ${tClass} ${localSelectedZone === z.id ? 'selected' : ''}`;
            d.style.opacity = accessible ? "1" : "0.3";
            d.onclick = () => { if(accessible) { localSelectedZone = z.id; render(); } };
            
            if(z.id === 0) d.innerHTML = "🏠 MAISON";
            else if(!z.type) d.innerHTML = `ZONE ${z.id}${accessible ? '' : '<br>🔒'}`;
            else {
                let entete = z.batiment && !isSerre ? `🏗️ ${z.batiment}` : z.type;
                d.innerHTML = `<span style="font-size:0.75em; opacity:0.7;">${entete}</span>`;
                if(z.culture) {
                    d.innerHTML += `<br><b>${z.culture.nom}</b><br>💧${z.culture.eCur} ☀️${z.culture.sCur}`;
                    const mure = z.culture.eCur <= 0 && z.culture.sCur <= 0;
                    if(mure) d.innerHTML += `<br><button onclick="actionRecolter(${z.id})" style="background:var(--p1); color:white; border:none; cursor:pointer; font-size:0.8em; margin-top:2px;">🧺 Récolter</button>`;
                }
            }
            grid.appendChild(d);
        });

        // Boutons d'action (Vérif Temps/Argent)
        renderActionButtons();
        
        // Vitrine Jardinerie
        updateMarketPreview();

        // Main du joueur
        renderHand();

        // Upgrades
        renderUpgrades();
    }

    function renderActionButtons() {
        const container = document.getElementById('action-buttons-container');
        let costTuile = state.upgrades[5] >= 2 ? (state.upgrades[5] === 3 ? 0 : 1) : 2;
        
        container.innerHTML = `
            <button class="btn-action" onclick="actionTuile('P')" style="background:#4caf50" ${state.time < 3 || state.money < costTuile ? 'disabled' : ''}>🏗️ Potager <span class="btn-cost">-3h | -${costTuile}💰</span></button>
            <button class="btn-action" onclick="actionTuile('V')" style="background:#fbc02d; color:#333;" ${state.time < 3 || state.money < costTuile ? 'disabled' : ''}>🏗️ Verger <span class="btn-cost">-3h | -${costTuile}💰</span></button>
            <button class="btn-action" onclick="actionAmenager()" style="background:#ff5722" ${state.time < 3 || state.money < 3 ? 'disabled' : ''}>🌳 Nature <span class="btn-cost">-3h | -3💰</span></button>
            <button class="btn-action" onclick="actionArroser()" style="background:#2196f3" ${state.time < 1 ? 'disabled' : ''}>💧 Arroser <span class="btn-cost">-1h</span></button>
            <button class="btn-action" onclick="prochaineSaison()" style="background:#e53935; grid-column: span 4;">💤 Fin de Saison (Sync)</button>
        `;
    }

    // --- FONCTIONS ACTIONS (MODIFIENT LE STATE ET SYNCHRONISENT) ---
    function actionTuile(t) {
        if(localSelectedZone === null || localSelectedZone === 0) return;
        let cost = state.upgrades[5] >= 2 ? (state.upgrades[5] === 3 ? 0 : 1) : 2;
        state.money -= cost; state.time -= 3;
        state.zones[localSelectedZone].type = t === 'P' ? 'POTAGER' : 'VERGER';
        syncState();
    }

    function actionAmenager() {
        if(localSelectedZone && state.money >= 3 && state.time >= 3) {
            state.money -= 3; state.time -= 3;
            state.zones[localSelectedZone].type = 'AMÉNAGEMENT';
            syncState();
        }
    }

    function actionArroser() {
        let z = state.zones[localSelectedZone];
        if(z && z.culture && state.time >= 1) {
            state.time -= 1; z.culture.eCur = Math.max(0, z.culture.eCur - 2);
            syncState();
        }
    }

    function actionRecolter(id) {
        let z = state.zones[id];
        if(state.time >= 2) {
            state.time -= 2;
            state.money += (z.culture.g + (state.upgrades[3]-1));
            z.culture = null;
            syncState();
        }
    }

    function prochaineSaison() {
        state.saisonIdx++; if(state.saisonIdx > 3) { state.saisonIdx = 0; state.annee++; }
        // Météo simplifiée pour le test multijoueur
        let p = 2; let s = 1;
        state.zones.forEach(z => { if(z.culture) { z.culture.eCur = Math.max(0, z.culture.eCur-p); z.culture.sCur = Math.max(0, z.culture.sCur-s); }});
        state.time = state.timeMax;
        syncState();
    }

    // [Fermeture des fonctions annexes renderHand, renderUpgrades, etc... à compléter pour ton site]
    function updateMarketPreview() {
        const previewDiv = document.getElementById('market-preview');
        if(!state.market) return;
        previewDiv.innerHTML = `🌾 <b>Cultures:</b> ${state.market.C.map(c=>c.nom).join(', ')}`;
    }

    function renderHand() {
        const hDiv = document.getElementById('player-hand');
        hDiv.innerHTML = state.hand.map((c, i) => `
            <div class="card"><b>${c.nom}</b> [${c.cat}]<br><button onclick="jouerCarte(${i})">Jouer</button></div>
        `).join('');
    }

    function renderUpgrades() {
        const upDiv = document.getElementById('up-grid');
        upDiv.innerHTML = UP_NAMES.map((name, i) => `
            <div class="up-card"><b>${name}</b><br>L${state.upgrades[i]}<br><button onclick="upgrade(${i})">UP</button></div>
        `).join('');
    }

    function upgrade(idx) {
        let cost = state.upgrades[idx] === 1 ? 3 : 5;
        if(state.time >= cost) { state.time -= cost; state.upgrades[idx]++; syncState(); }
    }
</script>
</body>
</html>
